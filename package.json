{
  "name": "sancho-ai-ime",
  "version": "0.5.1",
  "private": true,
  "description": "AI-native personal input method project.",
  "type": "module",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "./dev.command",
    "test": "node --test packages/*/test/*.test.js scripts/*.test.js",
    "release:check": "node scripts/check-release-gate.js",
    "release:sbom": "node scripts/generate-release-sbom.js",
    "release:pack": "node scripts/pack-release.js",
    "build:en-word-list": "node scripts/build-en-word-list.js",
    "menubar:dev": "npm run dev --workspace @sancho-ai-ime/menubar-app",
    "menubar:pack:mac": "npm run pack:mac --workspace @sancho-ai-ime/menubar-app",
    "menubar:package:mac": "npm run package:mac --workspace @sancho-ai-ime/menubar-app"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@cspell/dict-fullstack": "^3.2.9",
    "@cspell/dict-git": "^3.1.0",
    "@cspell/dict-node": "^5.0.9",
    "@cspell/dict-npm": "^5.2.38",
    "@cspell/dict-python": "^4.2.26",
    "@cspell/dict-software-terms": "^5.2.2",
    "@cspell/dict-sql": "^2.2.1",
    "@cspell/dict-typescript": "^3.2.3"
  }
}
